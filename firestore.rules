rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /entries/{entryId} {
      allow read: if true;
      allow create: if isValidEntry();
      allow update: if isLikeUpdate();
      allow delete: if false;
    }
  }

  function hasOnlyEntryFields() {
    return request.resource.data.keys().hasOnly([
      'hanzi',
      'mandarin',
      'pinyin',
      'village',
      'villageCustom',
      'villageLabel',
      'contributor',
      'audioUrl',
      'likes',
      'timestamp',
      'createdAt'
    ]);
  }

  function hasRequiredEntryFields() {
    return request.resource.data.keys().hasAll([
      'hanzi',
      'mandarin',
      'pinyin',
      'village',
      'villageCustom',
      'villageLabel',
      'contributor',
      'audioUrl',
      'likes',
      'timestamp',
      'createdAt'
    ]);
  }

  function shortString(field, maxLength) {
    return request.resource.data[field] is string &&
      request.resource.data[field].size() > 0 &&
      request.resource.data[field].size() <= maxLength;
  }

  function optionalString(field, maxLength) {
    return request.resource.data[field] is string &&
      request.resource.data[field].size() <= maxLength;
  }

  function isValidEntry() {
    return hasOnlyEntryFields() &&
      hasRequiredEntryFields() &&
      shortString('hanzi', 40) &&
      shortString('mandarin', 160) &&
      optionalString('pinyin', 120) &&
      shortString('village', 20) &&
      optionalString('villageCustom', 60) &&
      shortString('villageLabel', 60) &&
      shortString('contributor', 40) &&
      (request.resource.data.audioUrl == null ||
        (request.resource.data.audioUrl is string &&
          request.resource.data.audioUrl.matches('https://.*'))) &&
      request.resource.data.likes == 0 &&
      request.resource.data.timestamp is string &&
      request.resource.data.createdAt is number;
  }

  function isLikeUpdate() {
    return request.resource.data.diff(resource.data).changedKeys().hasOnly(['likes']) &&
      request.resource.data.likes == resource.data.likes + 1;
  }
}
